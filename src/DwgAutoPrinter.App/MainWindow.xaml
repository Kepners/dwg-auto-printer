<Window x:Class="DwgAutoPrinter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DWG Auto Printer"
        Width="1360"
        Height="860"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#111723"
        Topmost="True">
    <Window.Resources>
        <Color x:Key="CyanAccent">#31D6FF</Color>
        <Color x:Key="MintAccent">#59FFD4</Color>
        <Color x:Key="CardColor">#4DFFFFFF</Color>
        <Color x:Key="CardBorderColor">#6AFFFFFF</Color>
        <Color x:Key="ErrorColor">#FF6E6E</Color>
        <Color x:Key="SuccessColor">#9CFFCC</Color>

        <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource CyanAccent}" />
        <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.35" Color="#2B000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F0FCFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#233447" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Shell"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="#2B4B66" />
                                <Setter TargetName="Shell" Property="BorderBrush" Value="#80D7FFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="#173040" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Shell" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputStyle" TargetType="Control">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#F6FDFF" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1420" Offset="0" />
                <GradientStop Color="#172230" Offset="0.55" />
                <GradientStop Color="#1A3144" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas IsHitTestVisible="False" Opacity="0.35">
            <Ellipse Width="420" Height="420" Canvas.Left="-130" Canvas.Top="-120">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#3D2EDBFF" Offset="0" />
                        <GradientStop Color="#002EDBFF" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="360" Height="360" Canvas.Right="-80" Canvas.Top="540">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#3D59FFD4" Offset="0" />
                        <GradientStop Color="#0059FFD4" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Canvas>

        <Border x:Name="ShellCard"
                Margin="18"
                Style="{StaticResource GlassCardStyle}"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform Y="20" />
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="DWG Auto Printer"
                                   Foreground="#F0FDFF"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI Semibold" />
                        <TextBlock Text="Always-on-top AutoCAD controller with live monitoring and hard-stop control."
                                   Foreground="#CAEFF9"
                                   FontSize="13"
                                   Margin="0,3,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0">
                        <Border Background="#1A000000" CornerRadius="8" Padding="10,6" Margin="0,0,8,0">
                            <TextBlock x:Name="StatusText"
                                       Text="Idle"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="Bold" />
                        </Border>
                        <ProgressBar x:Name="RunProgress"
                                     Width="170"
                                     Height="10"
                                     IsIndeterminate="False"
                                     Visibility="Collapsed"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="#223042" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource GlassCardStyle}" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.8*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.ColumnSpan="4"
                                   Text="Execution Controls"
                                   Foreground="#DFF9FF"
                                   FontWeight="SemiBold"
                                   FontSize="15"
                                   Margin="0,0,0,8" />

                        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,14,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Job Folder" VerticalAlignment="Center" Foreground="#D6EEF7" Margin="0,0,12,0" />
                            <TextBox x:Name="FolderPathTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource InputStyle}"
                                     Background="#1D2A3A"
                                     BorderBrush="#55FFFFFF"
                                     BorderThickness="1"
                                     Padding="8,6"
                                     Text="C:\\" />
                            <Button Grid.Column="2"
                                    Content="Browse"
                                    Click="BrowseFolderButton_OnClick"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource GlowButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,12,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Batch Size" Foreground="#D6EEF7" Margin="0,0,0,4" />
                            <ComboBox x:Name="BatchSizeComboBox"
                                      Grid.Row="1"
                                      SelectedIndex="1"
                                      Background="#1D2A3A"
                                      Foreground="#F6FDFF"
                                      BorderBrush="#55FFFFFF"
                                      Padding="6">
                                <ComboBoxItem Content="3" />
                                <ComboBoxItem Content="5" />
                                <ComboBoxItem Content="8" />
                                <ComboBoxItem Content="10" />
                            </ComboBox>
                        </Grid>

                        <Grid Grid.Row="1" Grid.Column="2" Margin="0,0,12,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Revision Mode" Foreground="#D6EEF7" Margin="0,0,0,4" />
                            <ComboBox x:Name="RevisionModeComboBox"
                                      Grid.Row="1"
                                      SelectionChanged="RevisionModeComboBox_OnSelectionChanged"
                                      SelectedIndex="0"
                                      Background="#1D2A3A"
                                      Foreground="#F6FDFF"
                                      BorderBrush="#55FFFFFF"
                                      Padding="6">
                                <ComboBoxItem Content="NEXT" />
                                <ComboBoxItem Content="EXACT" />
                            </ComboBox>
                        </Grid>

                        <Grid Grid.Row="1" Grid.Column="3" Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Exact Revision" Foreground="#D6EEF7" Margin="0,0,0,4" />
                            <TextBox x:Name="ExactRevisionTextBox"
                                     Grid.Row="1"
                                     IsEnabled="False"
                                     Background="#1D2A3A"
                                     Foreground="#F6FDFF"
                                     BorderBrush="#55FFFFFF"
                                     Padding="8,6"
                                     Text="" />
                        </Grid>

                        <Grid Grid.Row="2" Grid.Column="0" Margin="0,0,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Description"
                                       VerticalAlignment="Center"
                                       Foreground="#D6EEF7"
                                       Margin="0,0,12,0" />
                            <TextBox x:Name="DescriptionTextBox"
                                     Grid.Column="1"
                                     Background="#1D2A3A"
                                     Foreground="#F6FDFF"
                                     BorderBrush="#55FFFFFF"
                                     Padding="8,6"
                                     Text="Construction Issue" />
                        </Grid>

                        <StackPanel Grid.Row="2"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                            <CheckBox x:Name="CloseAfterCheckBox"
                                      Content="Close Drawing After Process"
                                      IsChecked="True"
                                      Foreground="#D6EEF7"
                                      Margin="0,0,16,0" />
                            <CheckBox x:Name="AutoCadVisibleCheckBox"
                                      Content="Show AutoCAD"
                                      IsChecked="True"
                                      Foreground="#D6EEF7"
                                      Margin="0,0,16,0" />
                            <CheckBox x:Name="AlwaysOnTopCheckBox"
                                      Content="Always On Top"
                                      IsChecked="True"
                                      Checked="AlwaysOnTopCheckBox_OnChanged"
                                      Unchecked="AlwaysOnTopCheckBox_OnChanged"
                                      Foreground="#D6EEF7"
                                      Margin="0,0,16,0" />
                            <TextBlock Text="Timeout (min)"
                                       Foreground="#D6EEF7"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <TextBox x:Name="TimeoutMinutesTextBox"
                                     Width="56"
                                     Background="#1D2A3A"
                                     Foreground="#F6FDFF"
                                     BorderBrush="#55FFFFFF"
                                     Padding="6,4"
                                     Text="30" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="DeployLispButton"
                                Content="Deploy LISP To AutoCAD Locations"
                                Click="DeployLispButton_OnClick"
                                Style="{StaticResource GlowButtonStyle}"
                                Margin="0,0,12,0" />
                        <Button x:Name="StartButton"
                                Content="Start Batch Run"
                                Click="StartButton_OnClick"
                                Style="{StaticResource GlowButtonStyle}"
                                Margin="0,0,12,0" />
                        <Button x:Name="StopButton"
                                Content="Stop Immediately"
                                Click="StopButton_OnClick"
                                Style="{StaticResource GlowButtonStyle}"
                                IsEnabled="False"
                                Background="#452226"
                                BorderBrush="#88FF8C8C" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}" Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Live Monitor"
                                           Foreground="#D6FAFF"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <ListBox Grid.Row="1"
                                         x:Name="MonitorListBox"
                                         ItemsSource="{Binding MonitorLogs}"
                                         Background="#181F2A"
                                         BorderBrush="#33FFFFFF"
                                         BorderThickness="1"
                                         Foreground="#ECFCFF"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="12">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap">
                                                <Run Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Foreground="#8AE2FF" />
                                                <Run Text="  " />
                                                <Run Text="{Binding Message}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource GlassCardStyle}" Margin="8,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Error Log"
                                           Foreground="#FFD1D1"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />
                                <ListBox Grid.Row="1"
                                         x:Name="ErrorListBox"
                                         ItemsSource="{Binding ErrorLogs}"
                                         Background="#241B23"
                                         BorderBrush="#55FF8D8D"
                                         BorderThickness="1"
                                         Foreground="#FFE7E7"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="12">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap">
                                                <Run Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Foreground="#FF9E9E" />
                                                <Run Text="  " />
                                                <Run Text="{Binding Message}" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ShellCard"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.35" />
                    <DoubleAnimation Storyboard.TargetName="ShellCard"
                                     Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                     From="20"
                                     To="0"
                                     Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
