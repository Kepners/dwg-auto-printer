<Window x:Class="DwgAutoPrinter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DWG Auto Printer"
        Width="1360"
        Height="860"
        MinWidth="1120"
        MinHeight="730"
        WindowStartupLocation="CenterScreen"
        Background="#0A1320"
        Topmost="True">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#31D6FF" />
        <SolidColorBrush x:Key="CardBrush" Color="#E0162738" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#7A4C6A89" />
        <SolidColorBrush x:Key="InputBrush" Color="#15283B" />
        <SolidColorBrush x:Key="InputBorderBrush" Color="#4D6E8EAE" />
        <SolidColorBrush x:Key="TextBrush" Color="#EAF8FF" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#BFD9E8" />

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="26" ShadowDepth="0" Opacity="0.38" Color="#42000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#F5FCFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#1A3550" />
            <Setter Property="BorderBrush" Value="#6392C3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Shell"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="#244C72" />
                                <Setter TargetName="Shell" Property="BorderBrush" Value="#8BC8FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Shell" Property="Background" Value="#132F48" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Shell" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.03" Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.03" Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="CheckStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource SubtleTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,14,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#08111D" Offset="0" />
                <GradientStop Color="#112237" Offset="0.55" />
                <GradientStop Color="#173551" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas IsHitTestVisible="False" Opacity="0.28">
            <Ellipse Width="500" Height="500" Canvas.Left="-150" Canvas.Top="-160">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#5531D6FF" Offset="0" />
                        <GradientStop Color="#0031D6FF" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="400" Height="400" Canvas.Right="-120" Canvas.Top="520">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#5059FFD4" Offset="0" />
                        <GradientStop Color="#0059FFD4" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Canvas>

        <Border x:Name="ShellCard"
                Margin="18"
                Style="{StaticResource GlassCardStyle}"
                Opacity="0"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <TranslateTransform Y="16" />
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="DWG Auto Printer"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="41"
                                   FontWeight="Bold"
                                   FontFamily="Segoe UI Semibold" />
                        <TextBlock Text="AutoCAD batch runner with live monitor, preflight checks, and hard-stop."
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   FontSize="14"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="14,0,0,0">
                        <Border Background="#1A000000" CornerRadius="8" Padding="10,6" Margin="0,0,8,0">
                            <TextBlock x:Name="StatusText"
                                       Text="Idle"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="Bold" />
                        </Border>
                        <ProgressBar x:Name="RunProgress"
                                     Width="170"
                                     Height="10"
                                     IsIndeterminate="False"
                                     Visibility="Collapsed"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="#223042" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource GlassCardStyle}" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="0.9*" />
                            <ColumnDefinition Width="1.6*" />
                            <ColumnDefinition Width="1.1*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="4" Text="Execution Controls" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,10" />

                        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,14,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Job Folder" Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBox x:Name="FolderPathTextBox" Grid.Column="1" Style="{StaticResource InputTextBoxStyle}" />
                            <Button Grid.Column="2"
                                    Content="Browse"
                                    Click="BrowseFolderButton_OnClick"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource GlowButtonStyle}" />
                        </Grid>

                        <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,14,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Batch Size" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,4" />
                            <TextBox x:Name="BatchSizeTextBox" Grid.Row="1" Style="{StaticResource InputTextBoxStyle}" Text="3" />
                        </Grid>

                        <Grid Grid.Row="1" Grid.Column="2" Margin="0,0,14,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Description" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,4" />
                            <TextBox x:Name="DescriptionTextBox" Grid.Row="1" Style="{StaticResource InputTextBoxStyle}" Text="Construction Issue" />
                        </Grid>

                        <Grid Grid.Row="1" Grid.Column="3" Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Timeout (min)" Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,4" />
                            <TextBox x:Name="TimeoutMinutesTextBox" Grid.Row="1" Style="{StaticResource InputTextBoxStyle}" Text="30" />
                        </Grid>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"
                                   Text="Revision Strategy: automatic per drawing (no manual revision entry required)"
                                   Foreground="#8BE7FF"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />

                        <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <CheckBox x:Name="CloseAfterCheckBox" Style="{StaticResource CheckStyle}" Content="Close Drawing After Process" IsChecked="True" />
                            <CheckBox x:Name="AutoCadVisibleCheckBox" Style="{StaticResource CheckStyle}" Content="Show AutoCAD" IsChecked="True" />
                            <CheckBox x:Name="AlwaysOnTopCheckBox"
                                      Style="{StaticResource CheckStyle}"
                                      Content="Always On Top"
                                      IsChecked="True"
                                      Checked="AlwaysOnTopCheckBox_OnChanged"
                                      Unchecked="AlwaysOnTopCheckBox_OnChanged" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="DeployLispButton"
                                Content="Deploy LISP To AutoCAD Locations"
                                Click="DeployLispButton_OnClick"
                                Style="{StaticResource GlowButtonStyle}"
                                Margin="0,0,12,0" />
                        <Button x:Name="StartButton"
                                Content="Start Batch Run"
                                Click="StartButton_OnClick"
                                Style="{StaticResource GlowButtonStyle}"
                                Margin="0,0,12,0" />
                        <Button x:Name="StopButton"
                                Content="Stop Immediately"
                                Click="StopButton_OnClick"
                                Style="{StaticResource GlowButtonStyle}"
                                IsEnabled="False"
                                Background="#4A1F29"
                                BorderBrush="#B86D82" />
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource GlassCardStyle}" Margin="0,0,8,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Live Monitor" Foreground="#D4F5FF" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <ListBox Grid.Row="1"
                                         x:Name="MonitorListBox"
                                         ItemsSource="{Binding MonitorLogs}"
                                         Background="#111B2A"
                                         BorderBrush="#325473"
                                         BorderThickness="1"
                                         Foreground="#ECFCFF"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="12">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap">
                                                <Run Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Foreground="#7DDCFF" />
                                                <Run Text="  " />
                                                <Run Text="{Binding Message}" Foreground="#E9F8FF" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource GlassCardStyle}" Margin="8,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Error Log" Foreground="#FFCFCF" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <ListBox Grid.Row="1"
                                         x:Name="ErrorListBox"
                                         ItemsSource="{Binding ErrorLogs}"
                                         Background="#2A1820"
                                         BorderBrush="#8C475A"
                                         BorderThickness="1"
                                         Foreground="#FFE7E7"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas"
                                         FontSize="12">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock TextWrapping="Wrap">
                                                <Run Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Foreground="#FF9E9E" />
                                                <Run Text="  " />
                                                <Run Text="{Binding Message}" Foreground="#FFE9E9" />
                                            </TextBlock>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ShellCard"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.3" />
                    <DoubleAnimation Storyboard.TargetName="ShellCard"
                                     Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                     From="16"
                                     To="0"
                                     Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
</Window>
